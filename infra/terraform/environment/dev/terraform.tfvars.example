project     = "your-project"
environment = "dev"
region      = "us-east-1"

service_version    = "0.1.0"
api_version        = "v1"
log_retention_days = 14
cors_allow_origin  = "http://localhost:3000"

common_lambda_environment = {
  POWERTOOLS_LOG_SAMPLING_RATE = "1.0"
  CLOUDWATCH_NAMESPACE         = "YourProject/Lambda"
  CORS_ALLOW_HEADERS           = "Content-Type,Authorization,X-Correlation-Id"
  CORS_ALLOW_METHODS           = "GET,POST,PUT,PATCH,DELETE,OPTIONS"
}

rest_lambdas = {
  rest = {
    handler              = "skeleton_lambda_rest.handler.handler"
    artifact_source_path = "../../../../dist/skeleton-lambda-rest.zip"
    artifact_key         = "lambdas/rest.zip"
    routes = [
      {
        route              = "GET /skeleton/health"
        authorization_type = "NONE"
      },
      {
        route              = "GET /skeleton/me"
        authorization_type = "COGNITO"
      },
      {
        route              = "GET /skeleton/admin"
        authorization_type = "COGNITO"
      },
      {
        route              = "GET /skeleton/private"
        authorization_type = "AWS_IAM"
      },
    ]
    dynamodb_table_access = ["app"]
    s3_bucket_access      = ["primary"]
    timeout               = 29
    memory_size           = 256
  }
}

worker_lambdas = {
  worker = {
    handler               = "skeleton_lambda_worker.handler.handler"
    artifact_source_path  = "../../../../dist/skeleton-lambda-worker.zip"
    artifact_key          = "lambdas/worker.zip"
    dynamodb_table_access = ["app"]
    s3_bucket_access      = ["primary"]
    timeout               = 120
    memory_size           = 256
    queue = {
      name                            = "your-project-dev-worker"
      visibility_timeout_seconds      = 150
      batch_size                      = 5
      maximum_batching_window_seconds = 5
      create_dlq                      = true
      max_receive_count               = 3
      dlq_message_retention_seconds   = 1209600
      queue_depth_alarm_threshold     = 10
      queue_depth_evaluation_periods  = 3
      queue_depth_period_seconds      = 60
    }
  }
}

enable_cognito                = true
cognito_user_pool_name        = "your-project-dev-users"
cognito_user_pool_client_name = "your-project-dev-client"
cognito_groups = {
  admin = {
    description = "Administrative users with elevated API access."
    precedence  = 1
  }
}
cognito_domain_prefix = "your-project-dev-auth"
cognito_callback_urls = ["http://localhost:3000/api/auth/callback/cognito"]
cognito_logout_urls   = ["http://localhost:3000"]

dynamodb_tables = {
  app = {
    table_name = "your-project-dev-app"
    hash_key   = "pk"
    range_key  = "sk"
    attributes = [
      { name = "pk", type = "S" },
      { name = "sk", type = "S" }
    ]
    billing_mode                  = "PAY_PER_REQUEST"
    enable_point_in_time_recovery = true
  }
}

s3_buckets = {
  primary = {
    bucket_name        = "your-project-dev-data-001"
    force_destroy      = false
    versioning_enabled = true
    sse_algorithm      = "AES256"
    bucket_key_enabled = true
    lifecycle_rules    = []
  }
  artifacts = {
    bucket_name        = "your-project-dev-lambda-artifacts-001"
    force_destroy      = false
    versioning_enabled = true
    sse_algorithm      = "AES256"
    bucket_key_enabled = true
    lifecycle_rules    = []
  }
}
