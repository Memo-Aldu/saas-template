# aws-lambda-powertools service name (used in logs, traces, metrics)
POWERTOOLS_SERVICE_NAME=skeleton-lambda-worker

# Semantic version of the deployed artifact
SERVICE_VERSION=0.1.0

# Deployment environment: local | dev | qa | staging | prod
ENVIRONMENT=local

# The worker has CORS settings inherited from BaseAppSettings.
# Even though SQS workers don't serve HTTP responses, the shared settings
# class requires this field. Set it to any value for local dev.
CORS_ALLOW_ORIGIN=http://localhost:3000

# Optional — safe defaults are provided by BaseAppSettings

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL (default: INFO)
# POWERTOOLS_LOG_LEVEL=INFO

# Fraction of requests to log at DEBUG level regardless of log level (0.0–1.0)
# POWERTOOLS_LOG_SAMPLING_RATE=1.0

# Disable X-Ray tracing — useful for local dev where no daemon is running
# POWERTOOLS_TRACE_DISABLED=true

# Disable CloudWatch Embedded Metrics Format output in local dev
# POWERTOOLS_METRICS_DISABLED=true

# AWS region (default: us-east-1)
# APP_AWS_REGION=us-east-1

# CloudWatch metrics namespace (default: SAASTemplate/Lambda)
# APP_NAMESPACE=SAASTemplate/Lambda

